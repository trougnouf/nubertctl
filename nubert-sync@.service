[Unit]
Description=Nubert Volume Sync for speaker %I
After=pipewire.service pipewire-pulse.service nubert-daemon@%i.service
Requires=nubert-daemon@%i.service
StartLimitIntervalSec=0

[Service]
Type=simple
ExecStart=/usr/bin/nubert_pulseaudio_sync "%I"
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
